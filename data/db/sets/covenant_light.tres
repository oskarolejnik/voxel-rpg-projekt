[gd_resource type="Resource" script_class="SetResource" format=3]

[ext_resource type="Script" path="res://data/resources/StatModifier.gd" id="1_cl"]
[ext_resource type="Script" path="res://data/resources/SetResource.gd" id="2_cl"]
[ext_resource type="Script" path="res://data/resources/EffectResource.gd" id="3_cl"]

[sub_resource type="Resource" id="Resource_cl2"]
