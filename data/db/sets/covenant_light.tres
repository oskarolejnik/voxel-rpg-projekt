[resource]
script = ExtResource("2_cl")
id = &"covenant_light"
display_name = "Swiatlo Przymierza"
fixed_modifiers = Array[ExtResource("1_cl")]([SubResource("Resource_cl_fix")])
bonuses = {
2: [SubResource("Resource_cl2")],
4: [SubResource("Resource_cl4")],
6: [SubResource("Resource_cl6")]
}
procs = {
6: [SubResource("Resource_cl_proc")]
}
