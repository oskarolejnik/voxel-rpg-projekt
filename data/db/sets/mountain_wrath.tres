[gd_resource type="Resource" script_class="SetResource" format=3]

[ext_resource type="Script" path="res://data/resources/StatModifier.gd" id="1_mw"]
[ext_resource type="Script" path="res://data/resources/SetResource.gd" id="2_mw"]
[ext_resource type="Script" path="res://data/resources/EffectResource.gd" id="3_mw"]

[sub_resource type="Resource" id="Resource_mw2"]
script = ExtResource("1_mw")
stat = &"bleed_damage"
value = 8.0
tags = Array[StringName]([&"set", &"bleed"])
source = &"set"
source_id = &"mountain_wrath"

[sub_resource type="Resource" id="Resource_mw4"]
script = ExtResource("1_mw")
stat = &"crit_mult"
op = 0
value = 0.5
tags = Array[StringName]([&"set", &"crit"])
source = &"set"
source_id = &"mountain_wrath"

[sub_resource type="Resource" id="Resource_mw6"]
script = ExtResource("1_mw")
stat = &"damage"
op = 2
value = 0.15
tags = Array[StringName]([&"set"])
source = &"set"
source_id = &"mountain_wrath"

[sub_resource type="Resource" id="Resource_mw_fix"]
script = ExtResource("1_mw")
stat = &"damage"
value = 10.0
tags = Array[StringName]([&"set"])
source = &"set"
source_id = &"mountain_wrath"

[sub_resource type="Resource" id="Resource_mw_proc"]
script = ExtResource("3_mw")
id = &"mountain_wrath_6pc"
trigger = 0
chance = 1.0
cooldown = 1.5
magnitude = 20.0
duration = 4.0
radius = 5.0
payload = &"earthquake"
tags = Array[StringName]([&"set", &"bleed"])

[resource]
script = ExtResource("2_mw")
id = &"mountain_wrath"
display_name = "Gniew Gor"
fixed_modifiers = Array[ExtResource("1_mw")]([SubResource("Resource_mw_fix")])
bonuses = {
2: [SubResource("Resource_mw2")],
4: [SubResource("Resource_mw4")],
6: [SubResource("Resource_mw6")]
}
procs = {
6: [SubResource("Resource_mw_proc")]
}
