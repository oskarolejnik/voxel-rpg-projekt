[gd_resource type="Resource" script_class="PassiveNodeResource" format=3]

[ext_resource type="Script" path="res://data/resources/StatModifier.gd" id="1_sm"]
[ext_resource type="Script" path="res://data/resources/PassiveNodeResource.gd" id="2_pn"]

[sub_resource type="Resource" id="mod_mana"]
script = ExtResource("1_sm")
stat = &"mana_max"
op = 1
value = 0.2
tags = Array[StringName]([&"mage", &"arcane"])
source = &"tree"
source_id = &"mag_arcane_spark"

[resource]
script = ExtResource("2_pn")
id = &"mag_arcane_spark"
display_name = "Arkaniczna Iskra"
modifiers = Array[ExtResource("1_sm")]([SubResource("mod_mana")])
cost_points = 1
requires = Array[StringName]([])
min_level = 1
is_keystone = false
grants_skill = &""
