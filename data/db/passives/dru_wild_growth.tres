[sub_resource type="Resource" id="mod_wild_hp"]
script = ExtResource("1_sm")
stat = &"max_hp"
op = 1
value = 0.08
tags = Array[StringName]([&"nature", &"druid"])
source = &"tree"
source_id = &"dru_wild_growth"

[resource]
script = ExtResource("2_pn")
id = &"dru_wild_growth"
display_name = "Bujny Wzrost"
