[gd_resource type="Resource" script_class="PassiveNodeResource" format=3]

[ext_resource type="Script" path="res://data/resources/StatModifier.gd" id="1_sm"]
[ext_resource type="Script" path="res://data/resources/PassiveNodeResource.gd" id="2_pn"]

[sub_resource type="Resource" id="mod_dead_more"]
script = ExtResource("1_sm")
stat = &"crit_mult"
op = 2
value = 0.5
tags = Array[StringName]([&"ranger", &"ranged", &"keystone"])
