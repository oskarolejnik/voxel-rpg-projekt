source_id = &"rng_deadeye"

[sub_resource type="Resource" id="mod_dead_aspd"]
script = ExtResource("1_sm")
stat = &"attack_speed"
op = 1
value = -0.1
tags = Array[StringName]([&"ranger", &"keystone"])
source = &"tree"
source_id = &"rng_deadeye"

[resource]
script = ExtResource("2_pn")
id = &"rng_deadeye"
display_name = "Smiertelne Oko"
modifiers = Array[ExtResource("1_sm")]([SubResource("mod_dead_more"), SubResource("mod_dead_aspd")])
