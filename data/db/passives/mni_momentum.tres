source_id = &"mni_momentum"

[sub_resource type="Resource" id="mod_mom_dmg"]
script = ExtResource("1_sm")
stat = &"damage"
op = 1
value = 0.1
tags = Array[StringName]([&"chi", &"monk"])
source = &"tree"
source_id = &"mni_momentum"

[resource]
script = ExtResource("2_pn")
id = &"mni_momentum"
display_name = "Rozped"
modifiers = Array[ExtResource("1_sm")]([SubResource("mod_mom_ms"), SubResource("mod_mom_dmg")])
